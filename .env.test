# =============================================================
# Test-only environment (ADR-019)
# =============================================================
# Loaded automatically by vitest (see vitest.config.ts). Overrides
# SUPABASE_TEST_* and SUPABASE_* connection variables so the suite
# hits the dedicated test Supabase instance on ports 64321/64322
# instead of the dev instance on 54321/54322.
#
# To boot the test instance:
#   pnpm test:db:start
#
# Safe to commit — these are the well-known Supabase local defaults,
# identical on every developer machine.
# =============================================================

# ---- Test Supabase instance (project_id=recruitment-platform-test) ----
SUPABASE_TEST_URL=http://127.0.0.1:64321
SUPABASE_TEST_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_TEST_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SUPABASE_TEST_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ---- Next.js + shared code paths that read SUPABASE_* directly ----
# Integration tests that import production code (e.g. src/lib/db/*)
# end up reading NEXT_PUBLIC_SUPABASE_URL / SUPABASE_SECRET_KEY.
# Redirect those to the test instance too.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:64321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ---- App scaffolding ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TENANT_ID=00000000-0000-0000-0000-000000000000
APP_ENV=test
LOG_LEVEL=warn
