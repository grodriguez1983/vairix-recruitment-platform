# =============================================================
# Recruitment Data Platform — Environment variables
# =============================================================
# Copiar a `.env.local` para desarrollo y NUNCA committear.
# Ver CLAUDE.md sección "Operaciones prohibidas" antes de usar
# service role keys en scripts.
# =============================================================


# -------------------------------------------------------------
# Supabase — nuevo modelo de API Keys (2025+, ver ADR-003 §7)
#   Publishable key  → prefijo sb_publishable_ (reemplaza anon legacy)
#   Secret key       → prefijo sb_secret_      (reemplaza service_role legacy)
# Proyectos creados ≥ Nov 2025 ya no tienen anon/service_role.
# -------------------------------------------------------------

# URL pública del proyecto Supabase. Usada por el cliente del browser.
# Local: http://localhost:54321
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key — pública, safe para el browser. RLS protege la DB.
# Formato: sb_publishable_<token>. Reemplaza la antigua anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key — BYPASSEA RLS. NUNCA exponer al cliente.
# Formato: sb_secret_<token>. Reemplaza la antigua service_role key.
# Soporta N claves rotables y revocables individualmente (audit log).
# Solo en:
#   - Edge Functions (sync, embeddings, parser, normalizer)
#   - GitHub Actions (backfill)
#   - Scripts locales de admin
SUPABASE_SECRET_KEY=

# Project ref (para Supabase CLI)
SUPABASE_PROJECT_REF=

# Access token de Supabase CLI (para MCP de Supabase y CLI)
SUPABASE_ACCESS_TOKEN=


# -------------------------------------------------------------
# Teamtailor (ADR-004)
# -------------------------------------------------------------

# API token del tenant de Teamtailor. Scope: lectura de candidates,
# applications, jobs, stages, users, notes, files.
TEAMTAILOR_API_TOKEN=

# Versión de API. Confirmar contra docs oficiales antes de pinear.
# Ver teamtailor-api-notes.md §1. Al 2026-04 la vigente es 20240904.
TEAMTAILOR_API_VERSION=20240904

# Base URL — depende de la región del tenant. Ver la página
# "Claves API" del admin de Teamtailor (muestra la URL base exacta).
#   Global/EU : https://api.teamtailor.com/v1
#   NA        : https://api.na.teamtailor.com/v1
# Si el endpoint está mal, toda petición devuelve 401 aunque el token
# sea válido (el 401 es pre-auth check, no dice "wrong region").
TEAMTAILOR_BASE_URL=https://api.na.teamtailor.com/v1

# Rate limit configurado (tokens por segundo del bucket local).
# Default 4 = ~40 req/10s, un poco por debajo del ~50 req/10s oficial.
TEAMTAILOR_RATE_TOKENS_PER_SECOND=4
TEAMTAILOR_RATE_BURST=10

# Dry run para primer smoke test en staging. Ver operation-classification.md.
# Valores: 'true' o 'false'. Default false.
DRY_RUN=false


# -------------------------------------------------------------
# OpenAI (ADR-005)
# -------------------------------------------------------------

# API key con permisos sobre /v1/embeddings.
# No se usa para RAG en Fase 1.
OPENAI_API_KEY=

# Modelo de embeddings. Cambiar esto sin ADR es Tier 2 — el hash
# incluye el modelo, toda la DB se re-embebe.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Dimension del modelo. Debe coincidir con vector(N) en data-model.
OPENAI_EMBEDDING_DIM=1536


# -------------------------------------------------------------
# App
# -------------------------------------------------------------

# URL pública de la app (para signed URLs, redirects, callbacks).
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Tenant UUID fijo en Fase 1. En Fase 2 multi-tenant esto cambia.
# Ver ADR-003 §1.
APP_TENANT_ID=

# Umbral de meses sin application activa para considerar candidate
# dormant. Ver domain-glossary.md. Default 12.
DORMANT_THRESHOLD_MONTHS=12

# Intervalo del sync incremental en minutos dentro de horario laboral.
# Default 15.
SYNC_INTERVAL_MINUTES=15


# -------------------------------------------------------------
# Observability (Fase 1 mínima)
# -------------------------------------------------------------

# Nivel de log. Valores: debug, info, warn, error.
LOG_LEVEL=info

# Ambiente. Valores: local, staging, production.
APP_ENV=local


# -------------------------------------------------------------
# Desarrollo (solo local)
# -------------------------------------------------------------

# Si es 'true', Claude Code puede ejecutar comandos marcados como
# Tier 2 en operation-classification.md sin prompt adicional.
# NUNCA en production. Default unset = false.
CLAUDE_ALLOW_DESTRUCTIVE=
